# Environment Variables for Frontend E2E Tests

# Base URL for tests (default: http://localhost:3000)
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000

# API URL (for direct API testing if needed)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Test User Credentials
# These should match users seeded in your test database
TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=Password123

TEST_SELLER_EMAIL=seller@example.com
TEST_SELLER_PASSWORD=Password123

TEST_APPROVED_SELLER_EMAIL=approved-seller@example.com
TEST_APPROVED_SELLER_PASSWORD=Password123

TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=Password123

# Environment
NODE_ENV=test
ENVIRONMENT=test

# Browser Configuration
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=false

# Timeout Settings (in milliseconds)
PLAYWRIGHT_TIMEOUT=30000

# CI/CD Detection
# Set to true when running in CI environment
CI=false

# Test Parallel Workers (0 = auto-detect)
WORKERS=0

# Video Recording (on-failure, retain-on-failure, off)
VIDEO=on-failure

# Screenshots (only-on-failure, off)
SCREENSHOTS=only-on-failure

# Trace Collection (on, off, on-first-retry)
TRACE=on-first-retry

# Retry Count
RETRIES=0

# Report Format (html, json, list, junit)
REPORTS=html,json

# Debug Mode
DEBUG=false

# Slow Motion (ms - adds delay to actions)
SLOW_MO=0
